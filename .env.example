# Server Configuration
PORT=3001

# JWT & Authentication
JWT_SECRET=supersecretkey_change_in_production

# Admin Credentials
ADMIN_PASSWORD=admin

# DB Configuration
DB_PATH=./db/portfolio.db

# SMTP Email Configuration
SMTP_HOST=smtp
SMTP_PORT=587
SMTP_USER=YOUR_MAIL_ID
SMTP_PASS=YOUR_MAIL_PASSWORD

# Admin Email
ADMIN_EMAIL=YOUR_ADMIN_EMAIL

# Supabase Configuration
SUPABASE_URL=your_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: If using Supabase for Auth
SUPABASE_JWT_SECRET=your_jwt_secret

# Client-side Variables (Optional)
# Note: Only use VITE_ prefix for client-safe variables
# VITE_API_URL=http://localhost:3001

# DO NOT EXPOSE SENSITIVE SECRETS with VITE_ prefix!
# Secrets like API keys, database URLs, and passwords should NOT be prefixed with VITE_
